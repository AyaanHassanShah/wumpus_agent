{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/new",       "destination": "/api/new"       },
    { "source": "/api/move",      "destination": "/api/move"      },
    { "source": "/api/auto_step", "destination": "/api/auto_step" },
    { "source": "/api/reveal",    "destination": "/api/reveal"    },
    { "source": "/(.*)",          "destination": "/index.html"    }
  ]
}
